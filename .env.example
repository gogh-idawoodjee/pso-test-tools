APP_NAME="PSO Test Tools"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://pso-test-tools.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Primary App Database ─────────────────────────────
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=pso-test-tools
DB_USERNAME=root
DB_PASSWORD=

# ─── Shared Sanctum Token DB ─────────────────────────
SHARED_DB_DRIVER=sqlite
SHARED_DB_HOST=127.0.0.1
SHARED_DB_PORT=3306
SHARED_DB_DATABASE=path/to/shared.sqlite
SHARED_DB_USERNAME=root
SHARED_DB_PASSWORD=

# ─── Session / Queue / Cache ─────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database

QUEUE_CONNECTION=database

# ─── Broadcast / Filesystem ───────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public

# ─── Mail ─────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── AWS (optional) ───────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=true

# ─── External Services ───────────────────────────────
GOOGLE_MAPS_GEOCODING_API_KEY=
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0

# ─── Custom App Config ────────────────────────────────
MAIN_PASSWORD=
PSO_SERVICES_API=https://pso-services.test
PSO_SERVICES_API_VERSION=2
HASIDS_SALT=

# ─── R2 Cloudflare Storage ────────────────────────────
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REGION=auto
R2_BUCKET=pso-test-tools
R2_URL=
LIVEWIRE_TEMPORARY_UPLOAD_DISK=r2

# ─── Vite ─────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
